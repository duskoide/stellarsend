# StellarSend — environment template (copy to apps/api/.dev.vars for wrangler dev)
# NEVER commit real secrets. Server-side only — do not expose in the web app.

# ── Turso / libSQL ───────────────────────────
# IMPORTANT: the Workers-compatible client (@libsql/client/web, used by the API
# at runtime) does NOT support file: URLs — only "libsql:", "http(s):", "ws(s):".
# For `wrangler dev`, run `turso dev` first (starts a local libSQL server over
# HTTP) and point TURSO_URL at it. `file:./local.db` only works for scripts run
# directly under Node (e.g. drizzle-kit push/generate, drizzle/seed.ts), which
# use the Node-native @libsql/client — not the Worker runtime.
#   turso dev --db-file local.db   # then: TURSO_URL=http://127.0.0.1:8080
# Production: create a DB at turso.io and use its libsql:// URL + auth token.
TURSO_URL=http://127.0.0.1:8080
TURSO_AUTH_TOKEN=

# ── Stellar network ──────────────────────────
HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK=TESTNET

# ── Auth ─────────────────────────────────────
JWT_SECRET=changeme

# ── Stellar accounts / assets (server-side only) ──
# Distributor keypair — fund via friendbot on testnet.
DISTRIBUTOR_SECRET=S...
# Asset issuers (public keys). REQUIRED for all supported currencies; missing any
# will crash quotes for that asset. All issuer keys are printed by `pnpm --filter api db:seed`
# (drizzle/seed-stellar.ts).
BND_ISSUER=G...
KHR_ISSUER=G...
IDR_ISSUER=G...
LAK_ISSUER=G...
MYR_ISSUER=G...
MMK_ISSUER=G...
PHP_ISSUER=G...
SGD_ISSUER=G...
THB_ISSUER=G...
VND_ISSUER=G...
USD_ISSUER=G...
# Receiving anchor public key — on-chain DESTINATION for path payments (SEP-31 shape).
# Printed by drizzle/seed-stellar.ts. REQUIRED for POST /transfers/:id/submit.
RECEIVING_ANCHOR_PUBKEY=G...

# ── Web app (public) ─────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8787/api/v1
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
